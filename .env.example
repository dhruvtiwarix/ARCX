# ==============================================================================
# ARCX Environment Configuration Template
# 
# INSTRUCTIONS:
# 1. Copy this file and rename it to `.env`
# 2. Update the values below for your specific environment (local/staging/prod)
# 3. DO NOT commit the actual `.env` file to version control.
# ==============================================================================

# ── Django Core ───────────────────────────────────────────────────────────────
# Secret key used for cryptographic signing. Generate a new one for production.
DJANGO_SECRET_KEY=django-insecure-local-dev-key-change-me-in-production

# Enable debug mode. Set to False in production!
DEBUG=True

# Comma-separated list of host/domain names that this site can serve.
ALLOWED_HOSTS=localhost,127.0.0.1,backend

# ── Database (PostgreSQL) ─────────────────────────────────────────────────────
# These values must match the POSTGRES_* env vars in docker-compose.yml
DB_NAME=arcx_db
DB_USER=arcx_user
DB_PASSWORD=arcx_password
DB_HOST=db
DB_PORT=5432

# ── Redis / Celery ────────────────────────────────────────────────────────────
# Used as the Celery broker and result backend
REDIS_URL=redis://redis:6379/0

# ── Frontend (Vite) ───────────────────────────────────────────────────────────
# The base URL where the frontend expects the backend API to live.
# In local docker dev, the vite proxy handles this, but it's good practice.
VITE_API_BASE_URL=http://localhost:8000
